# Copy to .env and fill in values. Never commit .env.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# development | production | test
NODE_ENV=development

# HTTP listen port (optional, default: 5000)
# PORT=5000

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection URL (Prisma)
# Example: postgresql://USER:PASSWORD@localhost:5432/ledgerguard
DATABASE_URL=

# -----------------------------------------------------------------------------
# Auth (required)
# -----------------------------------------------------------------------------
# Long random string for signing JWTs (use a strong secret in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Access token lifetime (optional, default: 7d)
# JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Browser origin(s) allowed by the API (comma-separated).
# - In development, common local dev URLs are also permitted (see cors.js).
# - In production, this is required (validateEnv); only listed origins are allowed.
#
# Examples:
# CLIENT_URL=http://localhost:5173
# CLIENT_URL=https://your-app.vercel.app
# CLIENT_URL=https://your-app.vercel.app,https://your-app-git-preview.vercel.app
CLIENT_URL=http://localhost:5173
