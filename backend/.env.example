# PostgreSQL connection string (required)
DATABASE_URL=

# JWT signing secret — use a long random value in production (required)
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional: JWT lifetime (default: 7d)
# JWT_EXPIRES_IN=7d

# Browser origin allowed by CORS
# - Required when NODE_ENV=production (only this origin is allowed).
# - In development, if unset, local origins (e.g. Vite on :5173) are allowed.
CLIENT_URL="http://localhost:5173"

# Server port (optional, default 5000)
# PORT=5000
