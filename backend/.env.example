# PostgreSQL connection string (required)
DATABASE_URL=

# JWT signing secret — use a long random value in production (required)
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional: JWT lifetime (default: 7d)
# JWT_EXPIRES_IN=7d

# Browser origin(s) allowed by CORS (comma-separated, no spaces after commas optional)
# - Required when NODE_ENV=production (only these origins are allowed).
# - In development, local dev origins are also allowed (e.g. Vite on :5173).
# Render example (match your Vercel URL exactly, https, no trailing slash):
# CLIENT_URL=https://ledger-guard-three.vercel.app
# Optional second origin for Vercel preview deployments:
# CLIENT_URL=https://ledger-guard-three.vercel.app,https://your-app-git-branch-user.vercel.app
CLIENT_URL="http://localhost:5173"


# Server port (optional, default 5000)
# PORT=5000
